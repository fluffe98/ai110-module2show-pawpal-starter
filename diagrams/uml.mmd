classDiagram
    class Task {
        +str description
        +str due_time
        +str frequency
        +str priority
        +bool completed
        +date due_date
        +mark_complete()
    }

    class Pet {
        +str name
        +str species
        +str breed
        +List tasks
        +add_task(task)
        +remove_task(task)
        +get_tasks()
        +get_pending_tasks()
    }

    class Owner {
        +str name
        +str email
        +List pets
        +add_pet(pet)
        +remove_pet(pet)
        +get_all_tasks()
        +get_pet_names()
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks()
        +sort_by_time()
        +sort_by_priority()
        +filter_by_pet(pet_name)
        +filter_by_status(completed)
        +detect_conflicts()
        +mark_task_complete(pet_name, task)
        +generate_daily_plan()
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Scheduler "1" --> "1" Owner : manages